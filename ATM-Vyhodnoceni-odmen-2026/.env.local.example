# Google OAuth (Google Cloud Console → Credentials)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# NextAuth secret (vygeneruj: openssl rand -base64 32)
AUTH_SECRET=your-nextauth-secret

# URL aplikace (pro OAuth callback)
AUTH_URL=http://localhost:3001

# Lokální vývoj bez Google OAuth (admin session)
DEV_AUTH_BYPASS=true
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# Volitelné: omezit přihlášení na konkrétní domény (default: airteam.eu)
# ALLOWED_AUTH_EMAIL_DOMAINS=airteam.eu

# Upstash Redis — Upstash Console → Database → .env.local
# Nebo Vercel Dashboard → Storage → KV → .env.local (legacy KV_ proměnné fungují taky)
# Bez těchto proměnných app funguje v read-only režimu ze statických dat.
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
# Alternativně (Vercel KV legacy — stále fungují):
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# ClickUp integrace — automatické vytváření deal follow-up tasků
# CLICKUP_API_TOKEN: ClickUp → Settings → Apps → API Token
# CLICKUP_LIST_ID: z URL listu v ClickUpu (číslo za /list/)
# NEXT_PUBLIC_CLICKUP_CONFIGURED: nastav na "true" pokud chceš zobrazit tlačítko
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxx
CLICKUP_LIST_ID=901234567890
NEXT_PUBLIC_CLICKUP_CONFIGURED=true
